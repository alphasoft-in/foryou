---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header';
import Footer from '../components/Footer';
import ProductCard from '../components/ProductCard';

const allProducts = [
  {
    id: '1',
    title: 'Body Sienna',
    price: 110.00,
    imageUrl: '/images/productos/body-sienna.webp',
    isNew: true
  },
  {
    id: '2',
    title: 'Corset Dali',
    price: 135.00,
    imageUrl: '/images/productos/corset-dali.webp',
    isNew: true
  },
  {
    id: '3',
    title: 'Corset Lea',
    price: 125.00,
    imageUrl: '/images/productos/corset-lea.webp',
    isNew: false
  },
  {
    id: '4',
    title: 'Corset Lucia',
    price: 140.00,
    imageUrl: '/images/productos/corset-lucia.webp',
    isNew: true
  },
  {
    id: '5',
    title: 'Corset Zenit',
    price: 145.00,
    imageUrl: '/images/productos/corset-zenit.webp',
    isNew: false
  },
  {
    id: '6',
    title: 'Sweater Salma',
    price: 160.00,
    imageUrl: '/images/productos/sweater-salma.jpg',
    isNew: false
  }
];
---

<Layout title="Colección">
  <Header currentPath={Astro.url.pathname} client:load />

  <main class="flex-grow">
    {/* Hero Section */}
    <section 
      class="relative w-full flex items-center justify-center overflow-hidden"
      style="min-height: 40vh; padding-top: 10rem; padding-bottom: 6rem;"
    >
      <div 
        class="absolute inset-0 bg-cover bg-center bg-no-repeat"
        style="background-image: url('https://images.unsplash.com/photo-1441984904996-e0b6ba687e04?q=80&w=2070&auto=format&fit=crop');"
      ></div>
      <div class="absolute inset-0 bg-black/30 z-[1]"></div>
      
      <div class="relative z-10 text-center px-6 mt-16 md:mt-0">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-light text-white tracking-widest uppercase drop-shadow-lg">Nuestra Colección</h1>
      </div>
    </section>

    <div class="container mx-auto px-6 py-16">
      
      <div class="flex flex-col md:flex-row justify-between items-end mb-12">
        <div>
          <p class="text-gray-500 font-light uppercase tracking-widest text-sm">Todas las piezas ({allProducts.length})</p>
        </div>
        
        <div class="mt-6 md:mt-0 flex space-x-4">
          <select class="border-b border-gray-300 py-2 bg-transparent text-sm font-medium tracking-wider outline-none cursor-pointer">
            <option>Ordenar por: Destacados</option>
            <option>Precio: Menor a Mayor</option>
            <option>Precio: Mayor a Menor</option>
            <option>Nuevos ingresos</option>
          </select>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-10">
        {allProducts.map(product => (
          <ProductCard 
            id={product.id}
            title={product.title}
            price={product.price}
            imageUrl={product.imageUrl}
            isNew={product.isNew}
            client:visible
          />
        ))}
      </div>
      
    </div>
  </main>

  <Footer />
</Layout>
